# ---- REALISTIC condition augmentation (timing channels: idx 2=IAT, 3=jitter) ----
# Operates on NORMALIZED data, so we perturb in normalized space proportionally.
def condition_augment(seq):
    # seq: [B,30,5] tensor (normalized). Augment ~AUG_FRAC of flows. Sizes/dirs untouched.
    B=seq.shape[0]; out=seq.clone()
    pick=torch.rand(B,device=seq.device)<AUG_FRAC
    if pick.sum()==0: return out
    idx=pick.nonzero(as_tuple=True)[0]
    real=(out[idx].abs().sum(-1)>0).float()                       # [n,30] valid-packet mask

    # 1) LATENCY scaling: multiply IAT (ch2) by per-flow factor 0.7-1.5x (faster/slower path)
    lat=torch.empty(len(idx),1,device=seq.device).uniform_(0.7,1.5)
    out[idx,:,2]=out[idx,:,2]*lat*real + out[idx,:,2]*(1-real)

    # 2) CORRELATED JITTER: AR(1) noise on IAT (jitter is correlated, not white)
    noise=torch.randn(len(idx),30,device=seq.device)*0.10         # small std in normed space
    for tt in range(1,30): noise[:,tt]=0.6*noise[:,tt-1]+0.4*noise[:,tt]  # AR(1) correlation
    out[idx,:,2]=out[idx,:,2]+noise*real

    # 3) QUEUING GAP: occasionally inflate one inter-arrival (congestion stall)
    stall=(torch.rand(len(idx),device=seq.device)<0.3)            # 30% of aug flows get a stall
    if stall.sum()>0:
        si=idx[stall]; pos=torch.randint(1,30,(len(si),),device=seq.device)
        for k in range(len(si)): out[si[k],pos[k],2]=out[si[k],pos[k],2]+torch.empty(1,device=seq.device).uniform_(0.5,2.0)

    # 4) MILD PACKET LOSS: drop ~0-1 packet from some flows (realistic <2% loss), left-shift
    lose=(torch.rand(len(idx),device=seq.device)<0.3)
    if lose.sum()>0:
        for k in idx[lose]:
            n=int((out[k].abs().sum(-1)>0).sum())
            if n>5:
                drop=torch.randint(0,n,(1,)).item()
                kept=torch.cat([out[k,:drop],out[k,drop+1:],torch.zeros(1,5,device=seq.device)],0)
                out[k]=kept

    # recompute jitter (ch3) from perturbed IAT (ch2) — keep RFC3550 consistency (approx)
    out[idx,:,3]=torch.abs(out[idx,:,2])*real*0.5 + out[idx,:,3]*(1-real)  # light coupling
    return out

class SSMBlock(nn.Module):
    def __init__(s,dm,ds=16,e=2):
        super().__init__();s.di=e*dm;s.ds=ds
        s.in_proj=nn.Linear(dm,2*s.di);s.conv=nn.Conv1d(s.di,s.di,3,padding=2,groups=s.di)
        s.x_proj=nn.Linear(s.di,2*ds+1)
        s.A_log=nn.Parameter(torch.log(torch.arange(1,ds+1,dtype=torch.float32).repeat(s.di,1)))
        s.D=nn.Parameter(torch.ones(s.di));s.out_proj=nn.Linear(s.di,dm)
    def forward(s,x,mask):
        B,L,_=x.shape;xb,z=s.in_proj(x).chunk(2,-1)
        xc=F.silu(s.conv(xb.transpose(1,2))[...,:L].transpose(1,2))
        Bm,Cm,dt=torch.split(s.x_proj(xc),[s.ds,s.ds,1],-1);dt=F.softplus(dt);A=-torch.exp(s.A_log)
        a=torch.exp(dt.unsqueeze(-1)*A.unsqueeze(0).unsqueeze(0));bx=(dt*Bm).unsqueeze(2)*xc.unsqueeze(-1)
        mm=mask.view(B,L,1,1);a=a*mm+(1-mm);bx=bx*mm
        h=torch.zeros(B,s.di,s.ds,device=x.device);ys=[]
        for tt in range(L):h=a[:,tt]*h+bx[:,tt];ys.append((h*Cm[:,tt].unsqueeze(1)).sum(-1))
        return s.out_proj((torch.stack(ys,1)+s.D*xc)*F.silu(z))
class Encoder(nn.Module):
    def __init__(s,nf=5,dm=128,nl=2,ds=16,dp=0.1):
        super().__init__();s.embed=nn.Linear(nf,dm)
        s.blocks=nn.ModuleList([SSMBlock(dm,ds) for _ in range(nl)])
        s.norms=nn.ModuleList([nn.LayerNorm(dm) for _ in range(nl)])
        s.drop=nn.Dropout(dp);s.onorm=nn.LayerNorm(dm)
    def forward(s,seq):
        mask=(seq.abs().sum(-1)>0).float();x=s.embed(seq)
        for b,n in zip(s.blocks,s.norms):x=x+s.drop(b(n(x),mask))
        x=s.onorm(x);mm=mask.unsqueeze(-1);return (x*mm).sum(1)/mm.sum(1).clamp(min=1.0)

# ---- GATED FiLM (your deck's "Gated FiLM" — adds a learned gate vs plain FiLM) ----
class GatedFiLM(nn.Module):
    def __init__(s,n_ctx,dm,hidden=64):
        super().__init__()
        s.net=nn.Sequential(nn.Linear(n_ctx,hidden),nn.ReLU(),nn.Linear(hidden,2*dm))
        s.gate=nn.Sequential(nn.Linear(n_ctx,hidden),nn.ReLU(),nn.Linear(hidden,dm),nn.Sigmoid())
        s.dm=dm
        nn.init.zeros_(s.net[-1].weight); nn.init.zeros_(s.net[-1].bias)
    def forward(s,h,ctx):
        gb=s.net(ctx); gamma,beta=gb[:,:s.dm],gb[:,s.dm:]
        g=s.gate(ctx)                                   # per-feature gate [0,1]
        film=(1.0+gamma)*h + beta
        return g*film + (1.0-g)*h                       # gate blends FiLM vs identity
class GatedFiLMModel(nn.Module):
    def __init__(s,nf=5,n_ctx=6,dm=128,nl=2,ds=16,dp=0.1):
        super().__init__();s.encoder=Encoder(nf,dm,nl,ds,dp);s.film=GatedFiLM(n_ctx,dm)
        s.proj=nn.Sequential(nn.Linear(dm,dm),nn.BatchNorm1d(dm),nn.ReLU(),nn.Linear(dm,dm))
    def forward(s,seq,ctx): h=s.film(s.encoder(seq),ctx);return h,F.normalize(s.proj(h),dim=1)

def supcon_loss(z,y,tau=TAU):
    sim=z@z.T/tau; sim=sim-sim.max(1,keepdim=True).values.detach()
    y=y.view(-1,1); pos=(y==y.T).float(); pos.fill_diagonal_(0)
    lm=torch.ones_like(pos); lm.fill_diagonal_(0)
    exp=torch.exp(sim)*lm; logp=sim-torch.log(exp.sum(1,keepdim=True)+1e-9)
    return -((pos*logp).sum(1)/pos.sum(1).clamp(min=1)).mean()

model=GatedFiLMModel(meta["n_seq_feats"],N_CTX,128,2,16,0.1).to(DEVICE)
opt=torch.optim.AdamW(model.parameters(),lr=LR,weight_decay=1e-4)
def lr_at(ep): return LR*(ep+1)/WARMUP if ep<WARMUP else LR

# ---- 5G (raw -> normalize joint stats) ----
d5=np.load(FIVEG,allow_pickle=True)
def norm_seq(s):
    m=(np.abs(s).sum(-1,keepdims=True)>0).astype(np.float32); return ((s-sm)/ss*m).astype(np.float32)
fiveg_seq=norm_seq(d5["seq"]); fiveg_ctx=d5["ctx"].astype(np.float32) if "ctx" in d5 else np.zeros((len(fiveg_seq),N_CTX),np.float32)
if "ctx_mean" in meta["norm"]:
    cm=np.array(meta["norm"]["ctx_mean"],np.float32); cs=np.array(meta["norm"]["ctx_std"],np.float32); fiveg_ctx=((fiveg_ctx-cm)/cs).astype(np.float32)

@torch.no_grad()
def embed(seq,ctx,bs=512):
    model.eval();Z=[]
    for i in range(0,len(seq),bs):
        Z.append(model(torch.from_numpy(seq[i:i+bs]).float().to(DEVICE),
                       torch.from_numpy(ctx[i:i+bs]).float().to(DEVICE))[1].cpu().numpy())
    return np.concatenate(Z)
@torch.no_grad()
def embed_t(seq_t,ctx,bs=512):   # for already-tensor (perturbed) test
    model.eval();Z=[]
    for i in range(0,len(seq_t),bs):
        Z.append(model(seq_t[i:i+bs].to(DEVICE),torch.from_numpy(ctx[i:i+bs]).float().to(DEVICE))[1].cpu().numpy())
    return np.concatenate(Z)
def knn(rz,ry,qz,k=20):
    out=[]
    for i in range(0,len(qz),2048):
        s=qz[i:i+2048]@rz.T; idx=np.argpartition(-s,k,1)[:,:k]
        out.append(np.array([np.bincount(ry[v],minlength=NC).argmax() for v in idx]))
    return np.concatenate(out)
rng=np.random.default_rng(0)
def evalp(tag):
    ztr=embed(tr.seq,tr.ctx); zte=embed(te.seq,te.ctx)
    ri=np.concatenate([rng.choice(np.where(tr.y==c)[0],min(2000,(tr.y==c).sum()),replace=False) for c in range(NC)])
    pred=knn(ztr[ri],tr.y[ri],zte)
    q=te.proto=="quic"; t=te.proto=="tls"
    qa=(pred[q]==te.y[q]).mean(); ta=(pred[t]==te.y[t]).mean()
    # CLEAN invariance metric: heavily-perturb CESNET test, see if accuracy holds
    global AUG_FRAC; old=AUG_FRAC; AUG_FRAC=1.0
    pert=condition_augment(torch.from_numpy(te.seq).float()).cpu()
    AUG_FRAC=old
    zpe=embed_t(pert,te.ctx); pp=knn(ztr[ri],tr.y[ri],zpe)
    pert_acc=(pp==te.y).mean()
    # 5G (cosine to video — robust)
    cents=np.stack([zte[te.y==c].mean(0) for c in range(NC)]); cents/=np.linalg.norm(cents,axis=1,keepdims=True)
    z5=embed(fiveg_seq,fiveg_ctx); cos5=z5@cents[VS]; p5=knn(ztr[ri],tr.y[ri],z5)
    print(f"  [{tag}] QUIC={qa:.3f} TLS={ta:.3f} | PERTURBED-CESNET={pert_acc:.3f} (clean invariance metric) | 5G vote_vid={ (p5==VS).mean():.1%} cos_vid={np.median(cos5):.3f}")
    return qa,ta,pert_acc

best=-1
for ep in range(EPOCHS):
    model.train()
    for g in opt.param_groups: g["lr"]=lr_at(ep)
    tot=0;nb=0
    for seq,ctx,y in tl:
        seq,ctx,y=seq.to(DEVICE),ctx.to(DEVICE),y.to(DEVICE)
        seq=condition_augment(seq)              # <<< realistic condition aug
        _,z=model(seq,ctx); loss=supcon_loss(z,y)
        opt.zero_grad(); loss.backward(); opt.step(); tot+=loss.item();nb+=1
    if (ep+1)%5==0 or ep==EPOCHS-1:
        qa,ta,pa=evalp(f"ep{ep+1}")
        print(f"[ep{ep+1}] loss={tot/nb:.4f}")
        # guardrail: in-domain must hold (don't let aug make it forget)
        if qa>=0.82 and ta>=0.70:
            score=pa  # reward perturbation-robustness
            if score>best:
                best=score; torch.save({"model":model.state_dict(),"meta":meta,"epoch":ep+1,
                    "quic":qa,"tls":ta,"perturbed_acc":pa,"gated_film":True},f"{OUTDIR}/v_cond_best.pt")
                print(f"   ** saved (perturbed-robust={pa:.3f}, QUIC={qa:.3f}, TLS={ta:.3f})")
        else: print(f"   [in-domain dropped (QUIC={qa:.3f} TLS={ta:.3f}) — aug too strong, not saved]")
    else: print(f"[ep{ep+1}] loss={tot/nb:.4f}")
print(f"\nV-COND DONE. Gated FiLM + condition aug. Watch: in-domain holds, PERTURBED-CESNET high (robustness).")
