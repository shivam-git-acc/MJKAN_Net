# Copy this file to .env and fill in your values
# .env is git-ignored and never committed

# Required: HuggingFace token (read access is enough for eval, write for --push-hf)
HF_TOKEN=hf_your_token_here

# Where checkpoints are saved locally (default: ./checkpoints)
OUT_DIR=./checkpoints

# --- Dataset collection only (not needed for train/eval) ---

# Path to your local CESNET-QUIC22 download
# Download from: https://data.cesnet.cz/research/datasets/cesnet-quic22
CESNET_DATA_DIR=./cesnet_data

# Your own HF repo to push reproduced datasets into (leave blank to skip push)
# e.g. yourname/cesnet-baseline  — do NOT set this to donbosoc/shigan-mjkan-baseline
HF_DATASET_REPO=

# Where dataset collection output is saved locally (default: ./data)
DATA_DIR=./data
